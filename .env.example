# Vercel / локальна збірка панелі (обов'язково для продакшену)
# Без слеша в кінці. Після deploy Render підстав свій URL:
VITE_API_BASE_URL=https://traffic-cloud-api.onrender.com

# Маркетинг підтягує ціну з GET /v1/billing/plan (локально — http://127.0.0.1:8787)

# Опційно: URL головної сторінки (за замовчуванням — origin + /)
# VITE_MARKETING_HOME_URL=http://localhost:3000/

# Пряме посилання на .exe (поки на Render не задано DESKTOP_SETUP_DOWNLOAD_URL)
# VITE_DESKTOP_DOWNLOAD_URL=https://example.com/Traffic.Cloud.Setup.exe
