{
  "name": "traffic-cloud-remotion-promo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render TrafficCloudPromo ../marketing/public/promo/traffic-cloud-promo.mp4 --crf=14",
    "render:webm": "remotion render TrafficCloudPromo ../marketing/public/promo/traffic-cloud-promo.webm --codec=vp9 --crf=18",
